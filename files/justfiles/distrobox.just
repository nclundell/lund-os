distrobox-assemble-arch:
  @distrobox-assemble --file /usr/etc/distrobox/distrobox.ini --name Arch

distrobox-assemble-gaming:
  @distrobox-assemble --file /usr/etc/distrobox/distrobox.ini --name Gaming

distrobox-assemble-media:
  @distrobox-assemble --file /usr/etc/distrobox/distrobox.ini --name Media


